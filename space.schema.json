    "ServiceOverride": {
      "additionalProperties": true,
      "description": "Per-compose-service tweak inside an ``apps.<name>.services:`` map.\n\nCupli-specific fields are ``vars`` and ``ports`` — everything else is\ntreated as a docker-compose service spec and flushed verbatim to a\ngenerated ``docker-compose.inline.yml`` (it can extend an existing compose\nservice or create a brand-new one).\n\nSemantics:\n\n- ``vars`` merge on top of the parent app's ``vars`` (per-service wins).\n- ``ports`` REPLACES the parent app's list when present (``[]`` opts out).\n- Anything else (``image``, ``build``, ``command``, ``environment``,\n  ``volumes``, ``depends_on``, …) is plain compose syntax. ``${VAR}``\n  references are left untouched here and resolved by docker compose\n  against ``override.env``.",
      "properties": {
        "vars": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Vars",
          "type": "object"
        },
        "ports": {
          "title": "Ports",
          "default": null,
          "anyOf": [
            {
              "type": "string"
            },
            {
              "anyOf": [
                {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                {
                  "type": "null"
                }
              ]
            }
          ]
        },
        "image": {
          "type": "string",
          "description": "Image to pull or build."
        },
        "build": {
          "description": "Build context: a string path, or a mapping with `context`, `dockerfile`, `args`, etc.",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "context": {
                  "type": "string"
                },
                "dockerfile": {
                  "type": "string"
                },
                "target": {
                  "type": "string"
                },
                "args": {
                  "type": [
                    "object",
                    "array"
                  ]
                },
                "labels": {
                  "type": [
                    "object",
                    "array"
                  ]
                },
                "cache_from": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "cache_to": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "network": {
                  "type": "string"
                },
                "platforms": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": true
            }
          ]
        },
        "command": {
          "description": "Override the default command.",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "array"
            }
          ]
        },
        "entrypoint": {
          "description": "Override the default entrypoint.",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "array"
            }
          ]
        },
        "environment": {
          "description": "Environment variables. Map or list of KEY=VALUE entries.",
          "anyOf": [
            {
              "type": "object",
              "additionalProperties": {
                "type": [
                  "string",
                  "number",
                  "boolean",
                  "null"
                ]
              }
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "env_file": {
          "description": "Path(s) to .env files merged into `environment`.",
