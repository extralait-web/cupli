{
  "$defs": {
    "AppModel": {
      "additionalProperties": false,
      "description": "One ``apps[<name>]`` entry.\n\nAttributes:\n    bases: base names to inherit from (multi-inheritance, C3 ordered).\n    deps: cupli-level start dependencies, mode-tagged.\n    tags: free-form tags used by ``cupli start --tag``.\n    mode: how the service runs (``up``, ``oneshot``, ``disabled``).\n    composes: compose files defining this app's services.\n    service: docker-compose service binding for this app.\n        * Omit it: app drives the compose service whose name == app's name.\n        * String: name of the existing compose service to bind to.\n        * Mapping: inline single-service spec — any docker-compose fields,\n          service name defaults to the app's name. Removes the need for a\n          separate compose file when one service is enough.\n        Mutually exclusive with the ``services:`` map.\n    services: multi-service map for compound apps (celery + workers + beat).\n        Each entry can mix cupli-specific keys (``vars``, ``ports``) with\n        arbitrary docker-compose attributes.\n    ports: compose-style port mappings (``\"8000:8000\"``, ``\"127.0.0.1:8000:8000\"``,\n        ``\"5432:5432/tcp\"``) injected into the service's ``ports:`` block. ``${VAR}``\n        references are substituted in the app's scope.\n    forward_ssh: opt-in to forward ``SSH_AUTH_SOCK`` into the container.",
      "properties": {
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        },
        "repo": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Repo"
        },
        "branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Branch"
        },
        "post_clone": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Post Clone"
        },
        "vars": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Vars",
          "type": "object"
        },
        "envs": {
          "title": "Envs",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ]
        },
        "init_vars": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Init Vars",
          "type": "object"
        },
        "bases": {
          "title": "Bases",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "maxLength": 64,
                "minLength": 1,
                "pattern": "^[A-Za-z][A-Za-z0-9_-]*$",
                "type": "string"
              },
              "type": "array"
            }
          ]
        },
        "deps": {
          "title": "Deps",
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64,
                "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "anyOf": [
                  {
                    "type": "null"
                  },
                  {
                    "type": "string",
                    "enum": [
                      "service_started",
                      "service_healthy",
                      "service_completed_successfully"
                    ]
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "default",
                        "hook",
                        "full"
                      ]
                    }
                  },
                  {
                    "$ref": "#/$defs/DepSpec"
                  }
                ]
              }
            }
          ]
        },
        "tags": {
          "title": "Tags",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "maxLength": 32,
                "minLength": 1,
                "pattern": "^[a-z][a-z0-9_-]*$",
                "type": "string"
              },
              "type": "array"
            }
          ]
        },
        "mode": {
          "$ref": "#/$defs/ServiceMode",
          "default": "up"
        },
        "composes": {
          "title": "Composes",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ]
        },
        "service": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/ServiceOverride"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Service"
        },
        "services": {
          "title": "Services",
          "default": null,
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64,
                "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
              }
            },
            {
              "anyOf": [
                {
                  "patternProperties": {
                    "^[A-Za-z][A-Za-z0-9_-]*$": {
                      "$ref": "#/$defs/ServiceOverride"
                    }
                  },
                  "propertyNames": {
                    "maxLength": 64,
                    "minLength": 1
                  },
                  "type": "object"
                },
                {
                  "type": "null"
                }
              ]
            }
          ]
        },
        "ports": {
          "title": "Ports",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ]
        },
        "forward_ssh": {
          "default": false,
          "title": "Forward Ssh",
          "type": "boolean"
        }
      },
      "title": "AppModel",
      "type": "object"
    },
    "BaseAppModel": {
      "additionalProperties": false,
      "description": "One ``bases[<name>]`` entry.\n\nBases are inheritable templates included by apps. Their ``composes`` files\nare prepended to including-apps' compose list.\n\nAttributes:\n    composes: compose files to merge into including apps.",
      "properties": {
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        },
        "repo": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Repo"
        },
        "branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Branch"
        },
        "post_clone": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Post Clone"
        },
        "vars": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Vars",
          "type": "object"
        },
        "envs": {
          "title": "Envs",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ]
        },
        "init_vars": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Init Vars",
          "type": "object"
        },
        "composes": {
          "title": "Composes",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ]
        }
      },
      "title": "BaseAppModel",
      "type": "object"
    },
    "CommandArg": {
      "additionalProperties": false,
      "description": "One declared parameter of a ``commands[<name>]`` shortcut.\n\nAttributes:\n    name: identifier; used both as the ``{{name}}`` placeholder inside the\n        command's ``run`` line and as the CLI argument/option name.\n    help: short description shown in ``cupli <command> --help``.\n    type: value type — ``str`` (default), ``int``, or ``bool``.\n    option: when True the parameter is a ``--name`` option; otherwise a\n        positional argument. A ``bool`` type is always an option (flag).\n    short: optional single-letter alias for an option (``l`` renders ``-l``).\n    required: whether the parameter must be supplied. Mutually exclusive\n        with ``default``.\n    default: value substituted when the parameter is omitted.",
      "properties": {
        "name": {
          "maxLength": 64,
          "minLength": 1,
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*$",
          "title": "Name",
          "type": "string"
        },
        "help": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Help"
        },
        "type": {
          "default": "str",
          "enum": [
            "str",
            "int",
            "bool"
          ],
          "title": "Type",
          "type": "string"
        },
        "option": {
          "default": false,
          "title": "Option",
          "type": "boolean"
        },
        "short": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Short"
        },
        "required": {
          "default": false,
          "title": "Required",
          "type": "boolean"
        },
        "default": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Default"
        }
      },
      "required": [
        "name"
      ],
      "title": "CommandArg",
      "type": "object"
    },
    "CommandShortcut": {
      "additionalProperties": false,
      "description": "One ``commands[<name>]`` entry.\n\nBy default reachable only via ``cupli sc <name>``. Set\n``top_level: true`` to ALSO register it as a first-class ``cupli <name>``\nverb (collisions with builtin commands are ignored).\n\nAttributes:\n    container: one or more app names whose service runs the command. A bare\n        string is wrapped into a one-element list.\n    run: shell command line executed inside the container. Accepts a single\n        string (block scalars allowed) or a list of lines joined with\n        newlines. ``{{name}}`` placeholders are substituted from declared\n        ``args``.\n    workdir: working directory inside the container.\n    help: short help string shown in ``cupli --help``.\n    top_level: when True, the command is promoted to a top-level verb\n        so ``cupli <name>`` works alongside ``cupli sc <name>``.\n    group: optional label; top-level commands are grouped under it in\n        ``cupli --help`` and the ``cupli sc`` listing.\n    execute: strategy when ``container`` lists several apps — sequential\n        (fail-fast, default), continue, or parallel.\n    args: declared parameters surfaced as typed CLI arguments/options and\n        substituted into ``run`` via ``{{name}}`` placeholders. A bare list\n        of names is shorthand for required positional string arguments.\n    strict: when False (default), CLI tokens not matching a declared ``arg``\n        are forwarded verbatim to the end of the command (flags and\n        positionals alike); when True, an unknown token is rejected. Only\n        relevant when ``args`` is declared.",
      "properties": {
        "container": {
          "title": "Container",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "maxLength": 64,
                "minLength": 1,
                "pattern": "^[A-Za-z][A-Za-z0-9_-]*$",
                "type": "string"
              },
              "minItems": 1,
              "type": "array"
            }
          ]
        },
        "run": {
          "title": "Run",
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "string"
            }
          ]
        },
        "workdir": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Workdir"
        },
        "help": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Help"
        },
        "top_level": {
          "default": false,
          "title": "Top Level",
          "type": "boolean"
        },
        "group": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Group"
        },
        "execute": {
          "$ref": "#/$defs/ExecuteMode",
          "default": "sequential"
        },
        "args": {
          "title": "Args",
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "items": {
                "$ref": "#/$defs/CommandArg"
              },
              "type": "array"
            }
          ]
        },
        "strict": {
          "default": false,
          "title": "Strict",
          "type": "boolean"
        }
      },
      "required": [
        "container",
        "run"
      ],
      "title": "CommandShortcut",
      "type": "object"
    },
    "DepCondition": {
      "description": "Compose-style start condition for a ``apps[*].deps[<name>]`` entry.\n\nMirrors docker-compose ``depends_on.<svc>.condition``. When the condition is\nleft unset, cupli auto-picks ``service_completed_successfully`` for a\ndependency whose ``mode: oneshot`` and ``service_started`` otherwise.",
      "enum": [
        "service_started",
        "service_healthy",
        "service_completed_successfully"
      ],
      "title": "DepCondition",
      "type": "string"
    },
    "DepMode": {
      "description": "Dependency mode tag on ``apps[*].deps[<svc>]``.\n\nA dependency starts only when the invocation's mode intersects its mode\nset. ``DEFAULT`` covers the common ``cupli start`` path.",
      "enum": [
        "default",
        "hook",
        "full"
      ],
      "title": "DepMode",
      "type": "string"
    },
    "DepSpec": {
      "additionalProperties": false,
      "description": "One ``apps[*].deps[<name>]`` entry.\n\nCaptures both cupli's per-dep ``modes`` tags (used for ``cupli up --mode``\nfiltering) and the docker-compose ``depends_on`` semantics: ``condition``,\n``restart``, and ``required``. The list/string/null short forms in YAML\nare normalised into this spec by :func:`_deps_to_specs` before validation.\n\nAttributes:\n    modes: cupli-side mode tags. A dep is walked by ``--mode <m>`` only\n        when ``m`` is in this list.\n    condition: compose start condition. ``None`` (default) → cupli picks\n        ``service_completed_successfully`` for a ``mode: oneshot`` dep and\n        ``service_started`` otherwise.\n    restart: when True, compose restarts the depending service if the\n        dependency restarts (compose ``depends_on.<svc>.restart``).\n    required: when False, the dep is \"soft\" — compose still starts the\n        depending service if the dep cannot start (compose\n        ``depends_on.<svc>.required: false``). Default True.",
      "properties": {
        "modes": {
          "items": {
            "$ref": "#/$defs/DepMode"
          },
          "title": "Modes",
          "type": "array"
        },
        "condition": {
          "anyOf": [
            {
              "$ref": "#/$defs/DepCondition"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "restart": {
          "default": false,
          "title": "Restart",
          "type": "boolean"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        }
      },
      "title": "DepSpec",
      "type": "object"
    },
    "ExecuteMode": {
      "description": "Execution strategy for a multi-container ``commands[*]`` shortcut.\n\n``SEQUENTIAL`` runs containers one by one and stops at the first failure\n(fail-fast). ``CONTINUE`` runs every container regardless of failures and\nreports an aggregate result. ``PARALLEL`` runs them concurrently, capturing\neach container's output to avoid interleaving.",
      "enum": [
        "sequential",
        "continue",
        "parallel"
      ],
      "title": "ExecuteMode",
      "type": "string"
    },
    "ExportModel": {
      "additionalProperties": false,
      "description": "One ``exports[<name>]`` entry.\n\nMaterialises a directory built inside a container (typically living in a\nnamed volume — ``node_modules``, optionally ``.venv``) onto the host so\nIDEs that only resolve from the local filesystem see it.\n\nExport is for IDE indexing, NOT for running host tooling: the exported\ntree may carry native binaries built for the image's libc, not the host's.\n\nAttributes:\n    from_app: the app (single) whose service owns the source directory.\n    exec_path: absolute POSIX source path inside the container.\n    path: host destination path (``${VAR}`` references resolved in scope).\n    strategy: ``sync`` (default — keep the named volume, copy to host on\n        ``refresh_on``) or ``bind-seeded`` (turn ``exec_path`` into a host\n        bind seeded from the image).\n    refresh_on: lifecycle events that trigger a refresh (default\n        ``[build]``).\n    gitignore: when True (default), add ``path`` to the root ``.gitignore``.\n    mac_volume: optional macOS volume consistency hint.\n    rewrite_paths: experimental — rewrite absolute container paths inside\n        exported files to their host equivalents on sync (for editable\n        ``.venv`` installs). Off by default; see ``E034``.",
      "properties": {
        "from": {
          "maxLength": 64,
          "minLength": 1,
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*$",
          "title": "From",
          "type": "string"
        },
        "exec_path": {
          "title": "Exec Path",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "strategy": {
          "$ref": "#/$defs/ExportStrategy",
          "default": "sync"
        },
        "refresh_on": {
          "title": "Refresh On",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "$ref": "#/$defs/RefreshHook"
              },
              "type": "array"
            }
          ]
        },
        "gitignore": {
          "default": true,
          "title": "Gitignore",
          "type": "boolean"
        },
        "mac_volume": {
          "anyOf": [
            {
              "$ref": "#/$defs/MacVolumeMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "rewrite_paths": {
          "default": false,
          "title": "Rewrite Paths",
          "type": "boolean"
        }
      },
      "required": [
        "from",
        "exec_path",
        "path"
      ],
      "title": "ExportModel",
      "type": "object"
    },
    "ExportStrategy": {
      "description": "Materialisation strategy for an ``exports[*]`` entry.\n\n``BIND_SEEDED`` turns the service's ``exec_path`` into a host bind seeded\nfrom the image (the container then writes directly to the host — always\nlive). ``SYNC`` keeps the named volume for container I/O and copies it to\nthe host one-way on ``refresh_on`` events (a read-mostly mirror for IDE\nindexing).",
      "enum": [
        "bind-seeded",
        "sync"
      ],
      "title": "ExportStrategy",
      "type": "string"
    },
    "HooksOverride": {
      "additionalProperties": false,
      "description": "Per-target hook overrides used by ``cupli set-hooks``.\n\nAttributes:\n    service: docker-compose service to exec into (default: target's service).\n    working_dir: working directory inside the container.\n    enabled: whether to install shims for this target.",
      "properties": {
        "service": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Service"
        },
        "working_dir": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Working Dir"
        },
        "enabled": {
          "default": true,
          "title": "Enabled",
          "type": "boolean"
        }
      },
      "title": "HooksOverride",
      "type": "object"
    },
    "HostBridgeSpec": {
      "additionalProperties": false,
      "description": "Expanded form of a mount's ``host_bridge`` declaration.\n\nUsed when the auto-derived host link (``<bind-source> + (exec_path −\nbind-target)``) is not what you want, or to opt out of relative symlinks.\n\nAttributes:\n    link: explicit host path for the bridge symlink. Overrides the\n        auto-derived link. ``${VAR}`` references are resolved in the\n        mount's scope. When ``None``, cupli derives the link from the\n        hosting app's workdir bind.\n    relative: when True (default), create a relative symlink so the\n        workspace stays portable across machines.",
      "properties": {
        "link": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Link"
        },
        "relative": {
          "default": true,
          "title": "Relative",
          "type": "boolean"
        }
      },
      "title": "HostBridgeSpec",
      "type": "object"
    },
    "MacVolumeMode": {
      "description": "macOS-specific volume consistency mode for performance tuning.",
      "enum": [
        "delegated",
        "cached",
        "consistent"
      ],
      "title": "MacVolumeMode",
      "type": "string"
    },
    "MountMode": {
      "description": "Bind-mount mode for ``mounts[*]``.",
      "enum": [
        "rw",
        "ro"
      ],
      "title": "MountMode",
      "type": "string"
    },
    "MountModel": {
      "additionalProperties": false,
      "description": "One ``mounts[<name>]`` entry.\n\nAttributes:\n    hosted_in: app names whose containers receive the mount.\n    exec_path: absolute POSIX path inside the container.\n    mode: read-write or read-only bind-mount.\n    mac_volume: optional macOS volume consistency hint.\n    host_bridge: opt-in host symlink so host tooling (IDEs, workspace\n        resolvers) sees the mount at the same relative path the container\n        uses. ``true`` enables auto-derivation; a mapping is a\n        :class:`HostBridgeSpec` for overrides. ``false`` (default) is off.",
      "properties": {
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        },
        "repo": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Repo"
        },
        "branch": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Branch"
        },
        "post_clone": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Post Clone"
        },
        "vars": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Vars",
          "type": "object"
        },
        "envs": {
          "title": "Envs",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          ]
        },
        "init_vars": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Init Vars",
          "type": "object"
        },
        "hosted_in": {
          "title": "Hosted In",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "maxLength": 64,
                "minLength": 1,
                "pattern": "^[A-Za-z][A-Za-z0-9_-]*$",
