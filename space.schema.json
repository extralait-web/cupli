  "additionalProperties": false,
  "description": "Schema for `space.cupli.yaml` — the cupli workspace specification.",
  "properties": {
    "schema_version": {
      "const": 1,
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "name": {
      "maxLength": 64,
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*$",
      "title": "Name",
      "type": "string"
    },
    "cupli_min": {
      "default": "0.1.0",
      "maxLength": 16,
      "minLength": 1,
      "pattern": "^(?:(\\d+)\\.)?(?:(\\d+)\\.)?(\\*|\\d+)$",
      "title": "Cupli Min",
      "type": "string"
    },
    "cupli_max": {
      "default": "*",
      "maxLength": 16,
      "minLength": 1,
      "pattern": "^(?:(\\d+)\\.)?(?:(\\d+)\\.)?(\\*|\\d+)$",
      "title": "Cupli Max",
      "type": "string"
    },
    "extends": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extends"
    },
    "envs": {
      "title": "Envs",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      ]
    },
    "vars": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Vars",
      "type": "object"
    },
    "bases": {
      "title": "Bases",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "patternProperties": {
            "^[A-Za-z][A-Za-z0-9_-]*$": {
              "$ref": "#/$defs/BaseAppModel"
            }
          },
          "propertyNames": {
            "maxLength": 64,
            "minLength": 1
          },
          "type": "object"
        }
      ]
    },
    "apps": {
      "minProperties": 1,
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_-]*$": {
          "$ref": "#/$defs/AppModel"
        }
      },
      "propertyNames": {
        "maxLength": 64,
        "minLength": 1
      },
      "title": "Apps",
      "type": "object"
    },
    "mounts": {
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_-]*$": {
          "$ref": "#/$defs/MountModel"
        }
      },
      "propertyNames": {
        "maxLength": 64,
        "minLength": 1
      },
      "title": "Mounts",
      "type": "object"
    },
    "hooks": {
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_-]*$": {
          "$ref": "#/$defs/HooksOverride"
        }
      },
      "propertyNames": {
        "maxLength": 64,
        "minLength": 1
      },
      "title": "Hooks",
      "type": "object"
    },
    "commands": {
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_-]*$": {
          "$ref": "#/$defs/CommandShortcut"
        }
      },
      "propertyNames": {
        "maxLength": 64,
        "minLength": 1
      },
      "title": "Commands",
      "type": "object"
    },
    "networks": {
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_-]*$": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "propertyNames": {
        "maxLength": 64,
        "minLength": 1
      },
      "title": "Networks",
      "type": "object"
    },
    "volumes": {
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_-]*$": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "propertyNames": {
        "maxLength": 64,
        "minLength": 1
      },
      "title": "Volumes",
      "type": "object"
    },
    "secrets": {
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_-]*$": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "propertyNames": {
        "maxLength": 64,
        "minLength": 1
      },
      "title": "Secrets",
      "type": "object"
    },
    "configs": {
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_-]*$": {
          "additionalProperties": true,
          "type": "object"
        }
      },
      "propertyNames": {
        "maxLength": 64,
        "minLength": 1
      },
      "title": "Configs",
      "type": "object"
    },
    "exports": {
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_-]*$": {
          "$ref": "#/$defs/ExportModel"
        }
      },
      "propertyNames": {
        "maxLength": 64,
        "minLength": 1
      },
      "title": "Exports",
      "type": "object"
    }
  },
  "required": [
    "name",
    "apps"
  ],
  "title": "cupli space",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
