                "type": "string"
              }
            },
            {
              "type": "object"
            }
          ]
        },
        "healthcheck": {
          "type": "object",
          "description": "Container healthcheck spec (test, interval, timeout, retries, start_period).",
          "additionalProperties": true
        },
        "restart": {
          "type": "string",
          "description": "Restart policy.",
          "enum": [
            "no",
            "always",
            "on-failure",
