                "type": "string"
              },
              {
                "type": "object"
              }
            ]
          }
        },
        "configs": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object"
              }
            ]
          }
        },
        "cpus": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string"
            }
          ],
          "description": "Number of CPUs to allocate."
        },
        "cpu_count": {
          "type": "integer"
        },
        "cpu_percent": {
          "type": "number"
        },
        "cpu_shares": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "string"
            }
          ]
        },
        "cpu_quota": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
